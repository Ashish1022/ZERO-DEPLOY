# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URI=redis://localhost:6379

# ─── AWS ──────────────────────────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ECS — for launching build containers
AWS_ECS_CLUSTER=
AWS_TASK_DEFINITION=
AWS_CONTAINER_NAME=build-server
AWS_SUBNET_ONE=
AWS_SUBNET_TWO=
AWS_SUBNET_THREE=
AWS_SECURITY_GROUP=

# S3 — artifact storage
AWS_S3_BUCKET=vercel-clone-outputs
AWS_S3_BUCKET_OUTPUT_PATH=https://<bucket>.s3.<region>.amazonaws.com/__outputs

# ─── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_BROKER=localhost:9092
KAFKA_USERNAME=
KAFKA_PASSWORD=

# ─── ClickHouse ───────────────────────────────────────────────────────────────
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DATABASE=default
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=

# ─── Email (Nodemailer) ───────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@yourdomain.com

# ─── WhatsApp OTP (Gallabox) ──────────────────────────────────────────────────
GALLABOX_API_KEY=
GALLABOX_API_SECRET=

# ─── Frontend (Next.js) ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_SERVER_URL=http://localhost:9000

# ─── API Server ───────────────────────────────────────────────────────────────
PORT=9000
CORS_ORIGIN=http://localhost:3000

# ─── S3 Reverse Proxy ─────────────────────────────────────────────────────────
S3_PROXY_PORT=8000
